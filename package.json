{
  "name": "mtg-arena-auto-tracker",
  "version": "1.2.2",
  "description": "Standalone MTG Arena auto-tracker - no Overwolf required",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "jest",
    "test:watch": "jest --watch",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.gronaldo44.mtg-arena-tracker",
    "productName": "MTG Arena Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!tests/**",
      "!cards.json",
      "!dist/**",
      "!*.log",
      "!.git/**",
      "!debug.js",
      "!sos-card-import/**",
      "sos-card-data.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "include": "installer.nsh"
    }
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/test_*.js"
    ],
    "testEnvironment": "node",
    "transform": {},
    "coverageProvider": "v8",
    "maxWorkers": 1
  },
  "keywords": [
    "mtg",
    "arena",
    "tracker",
    "magic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^24.13.3",
    "jest": "^30.3.0"
  }
}
